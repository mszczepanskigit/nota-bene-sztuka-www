		letter-spacing: 0.05em;
		text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.5);
	}

	.hero-title-secondary {
		font-family: 'Playfair Display', serif;
		font-size: 3rem;
		font-weight: 700;
		color: #fffbf5;
		margin: 0;
		text-align: left;
		line-height: 1.3;
		letter-spacing: 0.05em;
		text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.5);
	}

