---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { INSTAGRAM_URL, SUPERPROF_URL, CONTACT_EMAIL, WEBINAR_FORM_URL, WEB3FORMS_KEY } from '../config/links';

import pisaImg from '../../public/pisa.jpg';
import orangeImg from '../../public/orange.png';
import webinarImg from '../../public/webinar1.png';


const currentYear = new Date().getFullYear();
---

<Layout
	title={`Korepetycje z historii sztuki online | Matura ${currentYear}, olimpiada, egzaminy – Nota Bene Sztuka`}
	description="Korepetycje z historii sztuki online – przygotowanie do matury, olimpiady i egzaminów wstępnych na studia artystyczne. Indywidualne lekcje 1:1 i małe grupy. Sprawdź ofertę!"
>
	<header class="site-header">
		<div class="container header-inner">
			<a class="nav-brand" href="#hero">NOTA<br>BENE<br>SZTUKA</a>

			<button class="menu-toggle" aria-label="Toggle menu" aria-expanded="false">
				<span></span>
				<span></span>
				<span></span>
			</button>

			<nav class="nav">
				<a href="#oferta">OFERTA</a>
				<a href="#opinie">OPINIE</a>
				<a href="#kontakt">KONTAKT</a>
				<a href="#o-mnie">O MNIE</a>
				<a href="#webinary">WEBINARY</a>
				<a class="arrow-down" href="#bottom" aria-label="Scroll to bottom">↓</a>
			</nav>
		</div>
	</header>

	<div class="mobile-menu-backdrop"></div>
	<nav class="nav-mobile">
		<a href="#oferta">OFERTA</a>
		<a href="#opinie">OPINIE</a>
		<a href="#kontakt">KONTAKT</a>
		<a href="#o-mnie">O MNIE</a>
		<a href="#webinary">WEBINARY</a>
	</nav>

	<main>
		<section class="section hero" id="hero" aria-label="Hero">
			<div class="hero-content">
				<div class="hero-titles">
					<h1 class="hero-title-primary">KOREPETYCJE Z<br>HISTORII SZTUKI</h1>
					<h2 class="hero-title-secondary">MATURA <span id="current-year">{currentYear}</span><br>OLIMPIADA<br>EGZAMINY NA STUDIA<br>DLA PASJONATÓW</h2>
				</div>
				</div>

			<div class="hero-socials">
				<a class="social" href={INSTAGRAM_URL} rel="noopener noreferrer" target="_blank" aria-label="Instagram">
					<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
						<path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
						<line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
					</svg>
				</a>
				<a class="social fb-coming-soon" href="#" rel="noopener noreferrer" aria-label="Facebook">
					<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
					</svg>
					<span class="fb-tooltip">Już niedługo!</span>
				</a>
				<a class="social" href={SUPERPROF_URL} rel="noopener noreferrer" target="_blank" aria-label="Superprof">
					<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<circle cx="12" cy="12" r="10"></circle>
						<text x="12" y="16" text-anchor="middle" fill="currentColor" stroke="none" font-size="12" font-weight="bold" font-family="Arial, sans-serif">S</text>
					</svg>
				</a>
			</div>

				<a href="#oferta" class="hero-scroll-down" aria-label="Scroll to offer">
					<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<polyline points="6 9 12 15 18 9"></polyline>
					</svg>
				</a>
		</section>

		<section id="oferta" class="section oferta-section">
			<div class="oferta-container">
				<div class="oferta-header">
					<h2 class="oferta-title">Podobno interesujesz się historią sztuki?</h2>
					<div class="oferta-line"></div>
				</div>

				<div class="oferta-content">
					<div class="oferta-image">
						<Image
							src={pisaImg}
							alt="Korepetycje z historii sztuki – analiza dzieł i przygotowanie do matury"
							quality={90}
							format="webp"
							loading="lazy"
						/>
					</div>

					<div class="oferta-text">
						<p>
							Jeśli tak – to idealnie trafiłeś/trafiłaś!<br>
							Tu Marta, Twoja (już wkrótce) ulubiona<br>
							historyczka sztuki.<br><br>
							Pomagam uczniom ogarnąć<br>
							przygotowania do matury z historii<br>
							sztuki (nawet jeśli zostały nam trzy<br>
							miesiące do matury). Gotowy/a?
						</p>
						<a href="#kontakt" class="cta-button">Zapisz się!</a>
					</div>
				</div>
			</div>

			<div class="oferta-container oferta-cards-container">
				<h2 class="oferta-cards-title">Jak wyglądają zajęcia?</h2>

				<div class="oferta-cards-grid">
					<div class="oferta-card">
						<h3>Epoki i kontekst</h3>
						<p>Przerabiamy epoki w oparciu o kontekst historyczny i kulturowy (tak, on naprawdę robi różnicę). Dzieła z kanonu omawiamy na podstawie moich autorskich prezentacji, więc nie potrzebujesz dodatkowych książek – wszystko już przygotowałam.</p>
					</div>

					<div class="oferta-card">
						<h3>Analiza formalna</h3>
						<p>Analizy nie da się nauczyć na pamięć – dlatego uczymy się jej praktycznie. Tak, żebyś potrafił/potrafiła samodzielnie przeanalizować każde dzieło, nawet takie, którego wcześniej nie widziałeś/aś.</p>
					</div>

					<div class="oferta-card">
						<h3>Zadania maturalne</h3>
						<p>Ćwiczymy realne zadania maturalne. Dostajesz konkretne tipy egzaminacyjne i pracujesz na kartach pracy zgodnych z CKE, dzięki czemu wiesz, jak pisać, żeby zdobywać punkty.</p>
					</div>

					<div class="oferta-card">
						<h3>Wypracowanie maturalne</h3>
						<p>Uczymy się pisać wypracowanie krok po kroku. Pokazuję, jak sprawdza je egzaminator, co musi się w nim znaleźć i jak nie tracić punktów – a to aż ⅓ wyniku z matury.</p>
					</div>

					<div class="oferta-card">
						<h3>Forma zajęć</h3>
						<p>Zajęcia prowadzę indywidualnie (1:1) lub w małych grupach online. Pracujemy w Twoim tempie i robimy tyle powtórek, ile naprawdę potrzebujesz – bez presji. Plan zależy od czasu jaki pozostał nam do matury.</p>
					</div>

					<div class="oferta-card">
						<h3>Webinary i wyjścia do muzeów</h3>
						<p>Regularnie organizuję webinary maturalne oraz wspólne wyjścia do muzeów – bo historia sztuki najlepiej działa wtedy, gdy oglądamy dzieła na żywo 😉</p>
					</div>
				</div>
			</div>
		</section>

		<section id="opinie" class="section opinie-section">
			<div class="opinie-container">
				<div class="opinie-header">
					<h2 class="opinie-title">Opinie moich uczniów</h2>
					<div class="opinie-line"></div>
				</div>

				<div class="opinie-carousel-wrapper">
					<button class="opinie-nav opinie-nav-left" aria-label="Previous testimonial">‹</button>
					<button class="opinie-nav opinie-nav-right" aria-label="Next testimonial">›</button>

					<div class="opinie-carousel">
						<div class="opinie-cards-track">
							<div class="opinie-card">
								<p class="opinie-text">
									Pani Marta to doskonała
									korepetytorka, która potrafi
									idealnie dopasować materiał do
									wymogów egzaminu. Z ogromną
									pasją i zaangażowaniem
									przygotowała córkę do
									egzaminu wstępnego do
									Liceum Plastycznego. Córka
									zaliczyła egzamin teoretyczny z
									historii sztuki i wiedzy o sztuce
									z maksymalną liczbą punktów!
									Gorąco polecam.
								</p>
								<div class="opinie-card-line"></div>
								<p class="opinie-author">Mama Dominiki</p>
							</div>

							<div class="opinie-card">
								<p class="opinie-text">
									Bardzo dobre zajęcia
									indywidualne –
									wszystko było jasno
									wytłumaczone i
									pomogło mi przy
									wypracowaniu. Webinar
									też był super, ciekawy i
									dobrze poprowadzony.
									Polecam!
								</p>
								<div class="opinie-card-line"></div>
								<p class="opinie-author">Julia</p>
								<p class="opinie-role">Maturzystka 2025</p>
							</div>

							<div class="opinie-card">
								<p class="opinie-text">
									Naukę z historii sztuki zaczęłam
									chwilę tuż przy rozpoczęciu klasy
									maturalnej, czasu było mało by wpoić
									tak dużą dawkę wiedzy ale maturę
									udało mi się zdac na wynik
									zadawalający! Pani Marta świetnie
									umie dopasować harmonogram i
									rozłożyć materiał tak by każdemu
									nauka przychodziła bez wiekszego
									stresu. Zajęcia są urozmaicone o
									prezentację, dostęp do przeróżnych
									testów czy sprawdzenia z
									wypracowań. Z całego serduszka
									polecam!!
								</p>
								<div class="opinie-card-line"></div>
								<p class="opinie-author">Klaudia</p>
								<p class="opinie-role">Maturzystka 2024</p>
							</div>

							<div class="opinie-card">
								<p class="opinie-text">
									Pani Marta prowadzi lekcje w bardzo przyjemnej, profesjonalniej atmosferze. Zajęcia są ciekawe i zawsze dużo się z nich wynosi. Dzięki tym korepetycjom nauka stała się bardzo przyjemna i skuteczna.
								</p>
								<div class="opinie-card-line"></div>
								<p class="opinie-author">Klaudia</p>
								<p class="opinie-role">Maturzystka 2025</p>
							</div>

							<div class="opinie-card">
								<p class="opinie-text">
									Bardzo polecam! Oprócz przekazania wiedzy Marta umie zarazić entuzjazmem i uśmiechem co sprawia, że lekcje to sama przyjemność
								</p>
								<div class="opinie-card-line"></div>
								<p class="opinie-author">Maciej</p>
								<p class="opinie-role">Maturzysta 2025</p>
							</div>
						</div>
					</div>

					<div class="opinie-dots">
						<button class="opinie-dot active" data-index="0" aria-label="Go to testimonial 1"></button>
						<button class="opinie-dot" data-index="1" aria-label="Go to testimonial 2"></button>
						<button class="opinie-dot" data-index="2" aria-label="Go to testimonial 3"></button>
						<button class="opinie-dot" data-index="3" aria-label="Go to testimonial 4"></button>
						<button class="opinie-dot" data-index="4" aria-label="Go to testimonial 5"></button>
					</div>

					<p class="opinie-more">
						Więcej opinii tutaj: <a href={SUPERPROF_URL} rel="noopener noreferrer" target="_blank" aria-label="More testimonials">Superprof</a>
					</p>
				</div>
			</div>
		</section>

		<section id="kontakt" class="section kontakt-section">
			<div class="kontakt-container">
				<div class="kontakt-inner">
					<div class="kontakt-text">
						<h2 class="kontakt-title">Skontaktuj się ze mną</h2>
						<p>
							Masz pytania dotyczące zajęć? Chcesz umówić się na pierwsze spotkanie?
							Wypełnij formularz, a odezwę się do Ciebie najszybciej jak to możliwe.
						</p>
						<p>
							Ewentualnie napisz do mnie na poniższy adres e-mail!
						</p>
						<p class="kontakt-email">
							<a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>
						</p>
						<div class="kontakt-socials">
							<a href={INSTAGRAM_URL} rel="noopener noreferrer" target="_blank" aria-label="Instagram">
								<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
									<path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
									<line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
								</svg>
							</a>
							<a class="fb-coming-soon" href="#" rel="noopener noreferrer" aria-label="Facebook">
								<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
								</svg>
								<span class="fb-tooltip">Już niedługo!</span>
							</a>
							<a href={SUPERPROF_URL} rel="noopener noreferrer" target="_blank" aria-label="Superprof">
								<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<circle cx="12" cy="12" r="10"></circle>
									<text x="12" y="16" text-anchor="middle" fill="currentColor" stroke="none" font-size="12" font-weight="bold" font-family="Arial, sans-serif">S</text>
								</svg>
							</a>
						</div>
					</div>

					<div class="kontakt-form-wrapper">
						<form id="kontakt-form" class="kontakt-form" action="https://api.web3forms.com/submit" method="POST">
							<input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
							<input type="checkbox" name="botcheck" class="hidden" style="display: none;" />
							<input type="hidden" name="subject" value="Nowe zapytanie z formularza kontaktowego - Nota Bene Sztuka" />
							<input type="hidden" name="redirect" value="https://web3forms.com/success" />
							<div class="form-group">
								<label for="name">Imię i nazwisko</label>
								<input type="text" id="name" name="name" autocomplete="name" required />
							</div>

							<div class="form-group">
								<label for="email">E-mail</label>
								<input type="email" id="email" name="email" autocomplete="email" required />
							</div>

							<div class="form-group">
								<label for="phone">Telefon (opcjonalnie)</label>
								<input type="tel" id="phone" name="phone" autocomplete="tel" />
							</div>

							<div class="form-group">
								<label for="message">Wiadomość</label>
								<textarea id="message" name="message" rows="5" required></textarea>
							</div>

							<div class="form-group form-checkbox">
								<label for="consent-combined">
									<input
										type="checkbox"
										id="consent-combined"
										name="consent_combined"
										required
									/>
									<span>Akceptuję <a href="/polityka-prywatnosci" target="_blank" rel="noopener noreferrer">politykę prywatności</a> i <a href="/regulamin" target="_blank" rel="noopener noreferrer">regulamin</a>. Oświadczam, że ukończyłem 18 lat lub jestem pełnoprawnym opiekunem.</span>
								</label>
							</div>

							<div id="form-status" class="form-status"></div>

							<button type="submit" class="form-submit">Wyślij wiadomość</button>
						</form>
					</div>
				</div>
			</div>
		</section>

		<section id="o-mnie" class="section omnie-section">
			<div class="omnie-container">
				<div class="omnie-header">
					<h2 class="omnie-title">O mnie</h2>
					<div class="omnie-line"></div>
				</div>

			<div class="omnie-content">
				<div class="omnie-image-wrapper">
					<div class="omnie-bg-rectangle"></div>
					<div class="omnie-image">
						<Image
							src={orangeImg}
							alt="Marta – historyczka sztuki i nauczycielka, Nota Bene Sztuka"
							quality={90}
							format="webp"
							loading="lazy"
						/>
					</div>
				</div>

				<div class="omnie-text-wrapper">
					<p>
						Nazywam się Marta i jestem historyczką sztuki oraz nauczycielką z przygotowaniem pedagogicznym. Od 5 lat edukuję, popularyzuję wiedzę o sztuce oraz przygotowuję uczniów do matur, olimpiad i egzaminów wstępnych, pomagając im uporządkować materiał i nauczyć się analizy dzieł w sposób wymagany na egzaminach.
					</p>
					<p>
						Moje zajęcia wyróżniają się nie tylko skutecznym przygotowaniem merytorycznym, ale także zarażaniem pasją do sztuki. Oprócz regularnych lekcji organizuję webinary oraz cykliczne wyjścia do muzeów, które pozwalają zobaczyć omawiane dzieła na żywo i lepiej je zrozumieć.
					</p>
					<p>
						Sprawdź aktualną ofertę zajęć i wybierz formę przygotowań dopasowaną do Twojego celu.
					</p>
				</div>
			</div>
			</div>
		</section>

		<section id="webinary" class="section webinary-section">
			<div class="webinary-container">
				<div class="webinary-header">
					<h2 class="webinary-title">Webinary</h2>
					<div class="webinary-line"></div>
				</div>

			<a href={WEBINAR_FORM_URL} rel="noopener noreferrer" target="_blank" class="webinary-image-link">
				<Image
					src={webinarImg}
					alt="Webinary z historii sztuki – kliknij, aby się zapisać na najbliższy webinar maturalny"
					quality={90}
					format="webp"
					loading="lazy"
				/>
			</a>
		</div>
		<div id="bottom"></div>
	</section>
	</main>

	<footer class="site-footer">
		<div class="footer-container">
			<div class="footer-top">
				<div class="footer-brand">
					<a href="#hero">NOTA<br>BENE<br>SZTUKA</a>
				</div>

				<div class="footer-contact">
					<h3>Kontakt</h3>
					<p><a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a></p>
				</div>
			</div>

			<div class="footer-line"></div>

			<div class="footer-bottom">
				<div class="footer-social-section">
					<p class="footer-social-title">Zaobserwuj mnie!</p>
				<div class="footer-socials">
					<a href={INSTAGRAM_URL} rel="noopener noreferrer" target="_blank" aria-label="Instagram">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
							<path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
							<line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
						</svg>
					</a>
					<a class="fb-coming-soon" href="#" rel="noopener noreferrer" aria-label="Facebook">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
						</svg>
						<span class="fb-tooltip">Już niedługo!</span>
					</a>
					<a href={SUPERPROF_URL} rel="noopener noreferrer" target="_blank" aria-label="Superprof">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<circle cx="12" cy="12" r="10"></circle>
							<text x="12" y="16" text-anchor="middle" fill="currentColor" stroke="none" font-size="12" font-weight="bold" font-family="Arial, sans-serif">S</text>
						</svg>
					</a>
				</div>
				</div>

				<div class="footer-links">
					<a href="/regulamin" target="_blank" rel="noopener noreferrer">Regulamin</a>
					<a href="/polityka-prywatnosci" target="_blank" rel="noopener noreferrer">Polityka prywatności</a>
				</div>

				<div class="footer-back-to-top">
					<a href="#hero" aria-label="Back to top">↑ Powrót do góry</a>
				</div>
			</div>

			<div class="footer-bottom-info">
				<p class="footer-copyright">© {currentYear} Nota Bene Sztuka. Wszelkie prawa zastrzeżone.</p>
				<p class="footer-nip">NIP: 8982329532</p>
			</div>
		</div>
	</footer>
</Layout>

<style>
	.site-header {
		position: fixed;
		top: 0;
